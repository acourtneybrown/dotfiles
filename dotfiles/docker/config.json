{
	"auths": {
		"{{@@ personal_gitea_hostname @@}}": {},
		"index.docker.io": {}
	},
	"credHelpers": {
		"{{@@ personal_gitea_hostname @@}}": "1password",
		"index.docker.io": "1password"
	},
{%@@ if mac @@%}
	"currentContext": "desktop-linux",
{%@@ endif @@%}
	"plugins": {
		"-x-cli-hints": {
			"enabled": "true"
		},
		"ai": {
			"hooks": "build,buildx build,run,compose"
		},
		"compose": {
			"hooks": "logs,compose logs,compose attach,compose up"
		},
		"debug": {
			"hooks": "exec"
		},
		"scout": {
			"hooks": "pull,buildx build"
		}
	},
	"features": {
		"hooks": "true"
	}
}
